{
  "version": 1,
  "hooks": {
    "sessionEnd": [
      {
        "type": "command",
        "bash": ".github/hooks/secrets-scanner/scan-secrets.sh",
        "cwd": ".",
        "env": {
          "SCAN_MODE": "warn",
          "SCAN_SCOPE": "diff"
        },
        "timeoutSec": 30
      },
      {
        "type": "command",
        "bash": ".github/hooks/test-guard/run-tests.sh",
        "cwd": ".",
        "env": {
          "TEST_MODE": "block"
        },
        "timeoutSec": 120
      }
    ]
  }
}
